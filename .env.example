# =============================================================================
# Required
# =============================================================================

# Anthropic API key — get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_api_key_here

# Flask secret key — used for session encryption and CSRF tokens.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=your-secret-key-here

# =============================================================================
# Optional
# =============================================================================

# Password gate for the app. Set to require a password on the login screen.
# Leave unset (or remove the line) to disable authentication entirely.
# LOGIN_PASSWORD=choose-a-strong-password

# Absolute path where the SQLite database is stored. Defaults to ./data/
# DATABASE_DIR=/app/data

# Flask environment. Defaults to 'production' if not set.
# Set to 'development' for debug mode (never in production).
# FLASK_CONFIG=development
